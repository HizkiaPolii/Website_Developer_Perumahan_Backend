// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Example Models - sesuaikan dengan kebutuhan Anda

model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  name      String
  phone     String?
  password  String
  role      String  @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Unit {
  id        Int     @id @default(autoincrement())
  name      String
  location  String
  price     Float
  status    String  @default("available")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("units")
}

model Booking {
  id        Int     @id @default(autoincrement())
  userId    Int
  unitId    Int
  status    String  @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bookings")
}

model ActivityLog {
  id        Int     @id @default(autoincrement())
  userId    Int
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}
